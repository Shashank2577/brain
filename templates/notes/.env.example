# Database — workspace-shared in dev (provided by the dispatch shell) and Neon
# Postgres in production. Override only when running this template
# standalone outside the workspace.
# DATABASE_URL=file:./.data/notes.sqlite

# Better Auth shared secret (provided by the workspace shell when running
# under dispatch). Only required for standalone runs.
# BETTER_AUTH_SECRET=

# Where this app is mounted in the dispatch shell. Inherited from the
# workspace at boot.
# APP_BASE_PATH=/notes
